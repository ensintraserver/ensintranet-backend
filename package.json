  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "CHOKIDAR_USEPOLLING=false nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "generate:sql": "ts-node -r tsconfig-paths/register scripts/encrypt-for-sql.ts"
  },
  "dependencies": {
    "@apollo/server": "4.5.0",
    "@google-cloud/storage": "^7.16.0",
    "@graphql-tools/merge": "8.3.11",
    "@nestjs/apollo": "10",
    "@nestjs/common": "^8.0.0",
    "@nestjs/config": "2.2.0",
    "@nestjs/core": "^8.0.0",
    "@nestjs/graphql": "10",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^8.0.0",
    "@nestjs/schedule": "2.2.3",
    "@nestjs/typeorm": "^11.0.0",
    "@types/passport-kakao": "^1.0.3",
    "@types/passport-naver": "^1.0.4",
    "apollo-server-core": "^3.13.0",
    "apollo-server-express": "^3.13.0",
    "bcrypt": "^5.0.0",
    "cache-manager": "4",
    "cache-manager-redis-store": "2.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.13.2",
    "cookie-parser": "^1.4.7",
    "graphql": "15",
    "graphql-upload": "13.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-kakao": "^1.0.1",
    "passport-naver-v2": "^2.0.8",
    "redis": "4.6.7",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.2.0",
    "sharp": "^0.32.6",
    "typeorm": "0.3.1",
    "uuid": "^3.4.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^8.0.0",
    "@nestjs/schematics": "^8.0.0",
    "@nestjs/testing": "^8.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cache-manager": "4.0.6",
    "@types/cache-manager-redis-store": "2.x",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^4.17.13",
    "@types/graphql-upload": "8.0.12",
    "@types/jest": "27.5.0",
    "@types/node": "10.1.0",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^2.0.11",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "3.6.4",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "28.0.3",
    "prettier": "^2.3.2",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "28.0.1",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "4.0.0",
    "web-push": "^3.6.7",
    "@types/pg": "^8.10.9"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "resolutions": {
    "@types/node": "10.1.0"
  }
}
